<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <!-- Top-level ScrollContainer for small screen support -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnReceiptDone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Title Header -->
            <TextView
                android:id="@+id/txtReceiptHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ORDER RECEIPT"
                android:textColor="#8B8D99"
                android:textSize="14sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <!-- The Ticket Container Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/ticketCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="8dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#111322"
                app:layout_constraintTop_toBottomOf="@id/txtReceiptHeader"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp"
                    android:paddingHorizontal="24dp">

                    <!-- Green verified check circle -->
                    <ImageView
                        android:id="@+id/imgSuccessCheck"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_success_green"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Success State text -->
                    <TextView
                        android:id="@+id/txtPaymentSuccess"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Success"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="12dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/imgSuccessCheck" />

                    <!-- Thank you / Greeting subtext -->
                    <TextView
                        android:id="@+id/txtReceiptThankYou"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Thank you for shopping at ShoeMart, Mostafa! Your order has been placed successfully."
                        android:textColor="#8B8D99"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.2"
                        android:layout_marginTop="8dp"
                        app:layout_constraintTop_toBottomOf="@id/txtPaymentSuccess" />

                    <!-- First cutting dashed line divider -->
                    <View
                        android:id="@+id/divider1"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@drawable/dashed_line"
                        android:layout_marginTop="24dp"
                        app:layout_constraintTop_toBottomOf="@id/txtReceiptThankYou" />

                    <!-- Details Box -->
                    <LinearLayout
                        android:id="@+id/layoutMetaDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/divider1">

                        <!-- Reference number -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reference number"
                                android:textColor="#8B8D99"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/txtReceiptRef"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="000085752257"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"/>
                        </RelativeLayout>

                        <!-- Date & time -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date &amp; time"
                                android:textColor="#8B8D99"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/txtReceiptDateTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="22 Mar 2026, 07:43 AM"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"/>
                        </RelativeLayout>

                        <!-- Payment method -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Payment method"
                                android:textColor="#8B8D99"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/txtReceiptMethod"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Credit Card"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"/>
                        </RelativeLayout>

                    </LinearLayout>

                    <!-- Second cutting dashed line divider -->
                    <View
                        android:id="@+id/divider2"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@drawable/dashed_line"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/layoutMetaDetails" />

                    <!-- Price breakdown (Delivery fee removed per request!) -->
                    <LinearLayout
                        android:id="@+id/layoutPriceDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/divider2">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Subtotal"
                                android:textColor="#8B8D99"
                                android:textSize="13sp"/>
                            <TextView
                                android:id="@+id/txtReceiptSubtotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="৳18,500.00"
                                android:textColor="#FFFFFF"
                                android:fontFamily="sans-serif-medium"
                                android:textSize="13sp"/>
                        </RelativeLayout>

                    </LinearLayout>

                    <!-- Third cutting dashed line divider -->
                    <View
                        android:id="@+id/divider3"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="@drawable/dashed_line"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/layoutPriceDetails" />

                    <!-- Grand Total block -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/divider3">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:text="Total"
                            android:textColor="#8B8D99"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black"/>
                        <TextView
                            android:id="@+id/txtReceiptTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="৳18,500.00"
                            android:textColor="#FF1744"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-black"/>
                    </RelativeLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Circular Overlapping Side Notches (Notch Anchor is aligned to divider1) -->
            <View
                android:id="@+id/notchLeft"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/circle_mask"
                app:layout_constraintTop_toTopOf="@id/ticketCard"
                app:layout_constraintBottom_toBottomOf="@id/ticketCard"
                app:layout_constraintStart_toStartOf="@id/ticketCard"
                app:layout_constraintEnd_toStartOf="@id/ticketCard"
                android:translationY="20dp"/> <!-- approximate y-offset to sit on divider1 -->

            <View
                android:id="@+id/notchRight"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/circle_mask"
                app:layout_constraintTop_toTopOf="@id/ticketCard"
                app:layout_constraintBottom_toBottomOf="@id/ticketCard"
                app:layout_constraintStart_toEndOf="@id/ticketCard"
                app:layout_constraintEnd_toEndOf="@id/ticketCard"
                android:translationY="20dp"/> <!-- approximate y-offset to sit on divider1 -->

            <!-- Serrated/Scalloped bottom wave shapes covering card edge -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintBottom_toBottomOf="@id/ticketCard"
                app:layout_constraintStart_toStartOf="@id/ticketCard"
                app:layout_constraintEnd_toEndOf="@id/ticketCard"
                android:translationY="10dp">

                <!-- 16 contiguous small overlapping wave-mask circles -->
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />
                <View android:layout_width="20dp" android:layout_height="20dp" android:layout_marginHorizontal="-2dp" android:background="@drawable/circle_mask" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom Navigation action -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnReceiptDone"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="24dp"
        android:background="@drawable/pink_rounded_button"
        android:text="Done &amp; Return to Home"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-black"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
