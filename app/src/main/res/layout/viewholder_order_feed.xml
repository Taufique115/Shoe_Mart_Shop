<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Name and Total BDT -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtCustomerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mostafa Jaman Taufique"
                android:textColor="#1E1E1E"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/txtOrderTotal"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/txtOrderTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BDT 18,500.00"
                android:textColor="#FF1744"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <!-- Second Row: Email and Date -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/txtCustomerEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="mostafataufique@gmail.com"
                android:textColor="#888888"
                android:textSize="11sp"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/txtOrderDate"
                android:layout_marginEnd="16dp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:id="@+id/txtOrderDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="May 18, 12:54 AM"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginVertical="12dp" />

        <!-- Third Row: Purchased Item Summaries -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#FF7A00" />

            <TextView
                android:id="@+id/txtPurchasedItemsSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="1x Nike Air Zoom Pegasus, 1x Adidas Ultraboost"
                android:textColor="#444444"
                android:textSize="12sp"
                android:ellipsize="end"
                android:maxLines="2" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
